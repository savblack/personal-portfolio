---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import MobileMenu from '../../components/MobileMenu.astro';
import Footer from '../../components/Footer.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = projects.find(p => p.slug === slug);
---
<Base title={`${project?.title} — Savannah Black`}>
  <Nav />
  <MobileMenu />
  <div class="min-h-screen flex items-center justify-center bg-white pt-24">
    <div class="text-center">
      <h1 class="font-serif text-4xl mb-4">{project?.title}</h1>
      <p class="text-[var(--color-muted)] text-sm">Case study coming soon.</p>
    </div>
  </div>
  <Footer />
</Base>
