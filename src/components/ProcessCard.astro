---
interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
---
<div class="bg-[rgba(153,161,175,0.04)] rounded-2xl flex flex-col overflow-hidden">
  <!-- Text content -->
  <div class="p-7 pb-5">
    <h3 class="text-base font-medium tracking-tight mb-3">{title}</h3>
    <p class="text-[14px] leading-[1.6] text-dark/[0.38]">{description}</p>
  </div>
  <!-- Tall image placeholder zone -->
  <div class="flex-1 min-h-[140px] relative max-md:min-h-[100px]">
    <div class="absolute inset-0 bg-gradient-to-t from-[rgba(153,161,175,0.03)] to-transparent"></div>
  </div>
</div>
