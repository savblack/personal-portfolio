---
const line1 = "Strategy is invisible";
const line2 = "until it compounds.";
---
<!-- Gradient interlude — full-height warm rose to cream with hard edges -->
<section
  class="relative"
  style="height: 200vh; background: linear-gradient(180deg, #b87a92 0%, #c08498 12%, #c99aa8 28%, #d4aeb4 42%, #e0c0b8 56%, #e8d0c4 68%, #f0ddd0 80%, #f5e8dc 90%, #faf0e8 100%)"
  id="interlude"
>
  <div class="sticky top-0 h-screen flex items-center px-12 max-md:px-5">
    <div class="max-w-shell mx-auto w-full">
      <p class="font-serif text-[56px] leading-[1.12] tracking-[-0.02em] max-w-[700px] max-lg:text-[42px] max-md:text-[32px]">
        <span class="interlude-line1">{line1}</span><br />
        <span class="interlude-line2">{line2}</span>
      </p>
    </div>
  </div>
</section>

<style>
  .interlude-line1 {
    color: rgb(249, 250, 251);
    transition: color 0.4s ease;
  }
  .interlude-line2 {
    color: rgba(249, 250, 251, 0.5);
    transition: color 0.4s ease;
  }

  :global(.interlude-light) .interlude-line1 {
    color: rgb(12, 16, 24);
  }
  :global(.interlude-light) .interlude-line2 {
    color: rgba(12, 16, 24, 0.45);
  }
</style>

<script>
  const section = document.getElementById('interlude');
  if (section) {
    const sticky = section.querySelector('.sticky');
    function updateInterlude() {
      const rect = section.getBoundingClientRect();
      const progress = -rect.top / (rect.height - window.innerHeight);
      if (progress > 0.35) {
        sticky?.classList.add('interlude-light');
      } else {
        sticky?.classList.remove('interlude-light');
      }
    }
    window.addEventListener('scroll', updateInterlude, { passive: true });
    updateInterlude();
  }
</script>
