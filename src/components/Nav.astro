---
const links = [
  { href: '#work', label: 'Work' },
  { href: '/about', label: 'About' },
  { href: '#approach', label: 'Approach' },
];
const secondaryLinks = [
  { href: '#writing', label: 'Writing' },
  { href: '/contact', label: 'Contact' },
];
---
<nav class="fixed top-0 inset-x-0 z-50 flex items-center justify-between px-12 py-6 text-dark max-md:px-5">
  <a href="/" class="text-sm font-semibold tracking-tight">Savannah Black</a>

  <!-- Desktop links -->
  <div class="hidden md:flex items-center gap-8 text-sm font-[450] tracking-tight">
    {links.map(l => (
      <a href={l.href} class="opacity-50 hover:opacity-100 transition-opacity">{l.label}</a>
    ))}
    <span class="w-px h-4 bg-current opacity-20" aria-hidden="true"></span>
    {secondaryLinks.map(l => (
      <a href={l.href} class="opacity-50 hover:opacity-100 transition-opacity">{l.label}</a>
    ))}
  </div>

  <!-- Mobile hamburger -->
  <button
    class="md:hidden text-sm opacity-70"
    id="menuToggle"
    aria-label="Open menu"
    aria-expanded="false"
  >
    Menu
  </button>
</nav>
