---
const links = [
  { href: '#work', label: 'Work' },
  { href: '/about', label: 'About' },
  { href: '#approach', label: 'Approach' },
];
const secondaryLinks = [
  { href: '#writing', label: 'Writing' },
  { href: '/contact', label: 'Contact' },
];
---
<nav id="mainNav" class="fixed top-0 inset-x-0 z-50 flex items-center justify-between px-12 py-6 text-dark max-md:px-5">
  <a href="/" class="nav-brand text-sm font-semibold tracking-tight text-white">Savannah Black</a>

  <!-- Desktop links -->
  <div class="nav-links hidden md:flex items-center gap-8 text-sm font-[450] tracking-tight text-white">
    {links.map(l => (
      <a href={l.href} class="opacity-50 hover:opacity-100 transition-opacity">{l.label}</a>
    ))}
{secondaryLinks.map(l => (
      <a href={l.href} class="opacity-50 hover:opacity-100 transition-opacity">{l.label}</a>
    ))}
  </div>

  <!-- Scroll-collapsed MENU button (desktop) -->
  <button
    class="nav-menu-btn hidden md:block text-sm font-[450] tracking-tight text-white"
    aria-label="Open menu"
  >
    Menu
  </button>

  <!-- Mobile hamburger -->
  <button
    class="md:hidden text-sm text-white opacity-70"
    id="menuToggle"
    aria-label="Open menu"
    aria-expanded="false"
  >
    Menu
  </button>
</nav>

<style>
  .nav-brand {
    transition: opacity 0.3s ease;
  }
  .nav-links {
    transition: opacity 0.3s ease;
  }
  .nav-menu-btn {
    transition: opacity 0.3s ease, color 0.3s ease;
    opacity: 0 !important;
    pointer-events: none;
  }
  #menuToggle {
    transition: opacity 0.3s ease, color 0.3s ease;
  }

  .nav-scrolled .nav-brand,
  .nav-scrolled .nav-links {
    opacity: 0 !important;
    pointer-events: none;
  }
  .nav-scrolled .nav-menu-btn {
    opacity: 0.7 !important;
    pointer-events: auto;
  }
  .nav-scrolled .nav-menu-btn:hover {
    opacity: 1 !important;
  }
</style>

<script>
  const nav = document.getElementById('mainNav');
  const menuBtn = nav?.querySelector('.nav-menu-btn');
  const menuToggle = document.getElementById('menuToggle');

  // Scroll listener — toggle collapsed state
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        nav?.classList.toggle('nav-scrolled', window.scrollY > 80);
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });

  // Wire MENU button to open the existing mobile menu overlay
  menuBtn?.addEventListener('click', () => {
    menuToggle?.click();
  });

  // Adaptive menu button color — section-based dark/light detection
  function updateMenuColor() {
    const scrollY = window.scrollY;
    const hero = document.querySelector('section.text-light') as HTMLElement;
    const darkZone = document.querySelector('[data-dark-zone]') as HTMLElement;

    let isDark = false;

    // Hero section is dark
    if (hero && scrollY < hero.offsetTop + hero.offsetHeight) {
      isDark = true;
    }
    // The big gradient div (dark zone) containing work/writing/interlude
    else if (darkZone) {
      const zoneTop = darkZone.offsetTop;
      const zoneBottom = zoneTop + darkZone.offsetHeight;
      // Light at the very top of the gradient, dark after ~30% in
      const transitionPoint = zoneTop + darkZone.offsetHeight * 0.30;
      if (scrollY >= transitionPoint && scrollY < zoneBottom) {
        isDark = true;
      }
    }

    const color = isDark ? '#fff' : 'var(--color-dark)';
    if (menuBtn) (menuBtn as HTMLElement).style.color = color;
    if (menuToggle) menuToggle.style.color = color;
  }

  window.addEventListener('scroll', updateMenuColor, { passive: true });
  updateMenuColor();
</script>
