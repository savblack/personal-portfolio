<script>
  function updateSydneyTime() {
    const el = document.getElementById('sydneyTime');
    if (!el) return;
    el.textContent = new Date().toLocaleTimeString('en-AU', {
      timeZone: 'Australia/Sydney',
      hour: 'numeric',
      minute: '2-digit',
      hour12: true,
    });
  }
  updateSydneyTime();
  setInterval(updateSydneyTime, 60000);
</script>
