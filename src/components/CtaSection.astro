---
const headline = "Let's build something that compounds.";
const subtitle = "Find out how I chart the path from insight to impact — through strategy, systems, and building — turning ambitious ideas into things that actually work.";
const headlineWords = headline.split(' ');
const subtitleWords = subtitle.split(' ');
---
<!-- CTA — 200vh tall gradient section matching New Genre -->
<section
  class="relative"
  style="height: 200vh; background: linear-gradient(180deg, #e8dca0 0%, #e4cc90 8%, #e8b478 16%, #f0b46a 26%, #e09850 36%, #d86842 46%, #b8462e 56%, #843220 66%, #582414 74%, #381a10 82%, #28140e 90%, #1e1310 100%)"
  id="contact"
>
  <div class="grain-overlay" aria-hidden="true"></div>
  <div class="sticky top-0 h-screen flex flex-col justify-between px-12 py-16 max-md:px-5 max-md:py-10">
    <div></div>
    <div class="max-w-[820px]">
      <h2 class="font-serif text-[56px] leading-[1.12] tracking-[-0.02em] mb-3 max-lg:text-[42px] max-md:text-[32px]">
        {headlineWords.map((word) => (
          <span class="inline-block mr-[0.27em] cta-word">{word}</span>
        ))}
      </h2>
      <p class="font-serif text-[40px] leading-[1.15] tracking-[-0.02em] max-w-[780px] max-lg:text-[30px] max-md:text-[24px]">
        {subtitleWords.map((word) => (
          <span class="inline-block mr-[0.22em] cta-word-sub">{word}</span>
        ))}
      </p>
    </div>
    <div>
      <a
        href="mailto:sav.black@outlook.com"
        class="cta-btn inline-flex items-center gap-2.5 px-7 py-3.5 rounded-full text-sm font-medium tracking-tight transition-colors"
      >
        Get in touch
      </a>
    </div>
  </div>
</section>

<style>
  .grain-overlay {
    position: absolute;
    inset: 0;
    opacity: 0.60;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    pointer-events: none;
    z-index: 1;
  }

  .cta-word {
    color: var(--color-dark);
    transition: color 0.3s ease;
  }
  .cta-word-sub {
    color: rgba(12, 16, 24, 0.45);
    transition: color 0.3s ease;
  }
  .cta-btn {
    background: rgba(12, 16, 24, 0.08);
    color: var(--color-dark);
    transition: background 0.3s ease, color 0.3s ease;
  }
  .cta-btn:hover {
    background: rgba(12, 16, 24, 0.14);
  }

  /* As user scrolls into the darker part of the gradient, switch text to light */
  @media (prefers-color-scheme: dark), (prefers-color-scheme: light) {
    /* We use JS below to toggle .cta-dark class */
  }

  :global(.cta-dark) .cta-word {
    color: rgb(249, 250, 251);
  }
  :global(.cta-dark) .cta-word-sub {
    color: rgba(249, 250, 251, 0.5);
  }
  :global(.cta-dark) .cta-btn {
    background: rgba(249, 250, 251, 0.12);
    color: rgb(249, 250, 251);
  }
  :global(.cta-dark) .cta-btn:hover {
    background: rgba(249, 250, 251, 0.2);
  }
</style>

<script>
  const section = document.getElementById('contact');
  if (section) {
    const sticky = section.querySelector('.sticky');
    const observer = new IntersectionObserver(
      (entries) => {
        // Calculate how far we've scrolled through the section
        const rect = section.getBoundingClientRect();
        const progress = -rect.top / (rect.height - window.innerHeight);
        if (progress > 0.35) {
          sticky?.classList.add('cta-dark');
        } else {
          sticky?.classList.remove('cta-dark');
        }
      },
      { threshold: Array.from({ length: 20 }, (_, i) => i / 19) }
    );
    observer.observe(section);

    // Also listen to scroll for smoother updates
    window.addEventListener('scroll', () => {
      const rect = section.getBoundingClientRect();
      const progress = -rect.top / (rect.height - window.innerHeight);
      if (progress > 0.35) {
        sticky?.classList.add('cta-dark');
      } else {
        sticky?.classList.remove('cta-dark');
      }
    }, { passive: true });
  }
</script>
