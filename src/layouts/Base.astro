---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Savannah Black — Strategy, Systems & Products',
  description = 'Portfolio of Savannah Black — strategy, systems, and product work.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#280e01" />
  </head>
  <body class="min-h-screen">
    <!-- Mega gradient background -->
    <div
      class="absolute inset-x-0 top-0 -z-10 pointer-events-none"
      style="height: 250vh; background: linear-gradient(180deg, #1a0c01 0%, #1f1530 3%, #252040 6%, #2e3358 10%, #3d4f78 14%, #5a769f 20%, #7d9dbe 28%, #a3c0da 36%, #c1d3e6 44%, #d8e4f0 52%, #e8eff6 60%, #f2f5f9 70%, #f9fafb 82%, #ffffff 100%);"
      aria-hidden="true"
    >
      <div class="hero-grain"></div>
    </div>

    <slot />

    <style>
      .hero-grain {
        position: absolute;
        inset: 0;
        opacity: 0.60;
        mix-blend-mode: overlay;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-size: 200px 200px;
        pointer-events: none;
      }
    </style>
  </body>
</html>
