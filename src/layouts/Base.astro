---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Savannah Black — Strategy, Systems & Products',
  description = 'Portfolio of Savannah Black — strategy, systems, and product work.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#280e01" />
  </head>
  <body class="min-h-screen">
    <!-- Mega gradient background -->
    <div
      class="fixed inset-x-0 top-0 -z-10 pointer-events-none"
      style="height: 260vh; background: linear-gradient(180deg, #1a0c02 0%, #162040 8%, #2a4a78 16%, #4a6d9e 24%, #6d8fba 32%, #8daed0 40%, #b8d0e2 46%, #d4a8be 53%, #e0a0b0 58%, #e8b4a8 64%, #f0d0b8 72%, #fef9e1 84%, #f7f3f0 100%);"
      aria-hidden="true"
    ></div>

    <slot />
  </body>
</html>
