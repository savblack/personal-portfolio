---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Savannah Black — Strategy, Systems & Products',
  description = 'Portfolio of Savannah Black — strategy, systems, and product work.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#280e01" />
  </head>
  <body class="min-h-screen">
    <!-- Mega gradient background -->
    <div
      class="fixed inset-x-0 top-0 -z-10 pointer-events-none"
      style="height: 200vh; background: linear-gradient(180deg, #1a0c02 0%, #162040 6%, #2a4a78 13%, #4a6d9e 20%, #6d8fba 27%, #8daed0 33%, #b8d0e2 38%, #d4a8be 43%, #e0a0b0 48%, #e8b4a8 54%, #f0d0b8 62%, #fef9e1 78%, #f7f3f0 100%);"
      aria-hidden="true"
    ></div>

    <slot />
  </body>
</html>
