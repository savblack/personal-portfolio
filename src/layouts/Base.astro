---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Savannah Black — Strategy, Systems & Products',
  description = 'Portfolio of Savannah Black — strategy, systems, and product work.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#280e01" />
  </head>
  <body class="min-h-screen">
    <!-- Mega gradient background -->
    <div
      class="fixed inset-x-0 top-0 -z-10 pointer-events-none"
      style="height: 240vh; background: linear-gradient(180deg, #280e01 0%, #182644 15.26%, #5a769f 30.28%, #87a1c4 43.38%, #c1d3e6 58.83%, #fef9e1 79.71%, #f7f3f0 100%);"
      aria-hidden="true"
    ></div>

    <slot />
  </body>
</html>
